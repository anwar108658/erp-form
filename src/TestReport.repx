<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.devexpress.com/XtraReports/2008/Report">
  <Bands>
    <DetailBand HeightF="25">
      <Controls>
        <XRTable Borders="All" LocationFloat="0,0" SizeF="650,25">
          <XRTableRow>
            <XRTableCell Text="Order ID"/>
            <XRTableCell Text="Customer"/>
            <XRTableCell Text="Product"/>
            <XRTableCell Text="Quantity"/>
            <XRTableCell Text="Amount"/>
          </XRTableRow>
        </XRTable>
      </Controls>
    </DetailBand>

    <PageHeaderBand HeightF="40">
      <Controls>
        <XRLabel Text="Test Sales Order Report" Font="Arial, 16, style=Bold" LocationFloat="0,0" SizeF="650,30"/>
      </Controls>
    </PageHeaderBand>
  </Bands>
</Report>